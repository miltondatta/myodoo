<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="it_asset_return_wizard_view_form" model="ir.ui.view">
        <field name="name">it.asset.return.wizard.form</field>
        <field name="model">it.asset.return.wizard</field>
        <field name="arch" type="xml">
            <form string="Return Asset">
                <group>
                    <group>
                        <field name="asset_id" readonly="1"/>
                        <field name="employee_id" readonly="1"/>
                        <field name="return_date" required="1"/>
                    </group>
                    <group>
                        <field name="condition_on_return" required="1" widget="radio"/>
                        <field name="next_state" required="1" widget="radio"/>
                    </group>
                </group>
                <group string="Return Notes">
                    <field name="notes" nolabel="1" placeholder="Accessories returned, observed issues…"/>
                </group>
                <footer>
                    <button name="action_return" string="Confirm Return"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
