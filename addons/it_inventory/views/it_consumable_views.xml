<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="it_consumable_view_list" model="ir.ui.view">
        <field name="name">it.consumable.list</field>
        <field name="model">it.consumable</field>
        <field name="arch" type="xml">
            <list string="IT Consumables"
                  decoration-danger="needs_reorder == True">
                <field name="name"/>
                <field name="category"/>
                <field name="part_number" optional="hide"/>
                <field name="quantity_on_hand" string="On Hand"/>
                <field name="reorder_qty" string="Reorder At"/>
                <field name="uom_id" string="UOM"/>
                <field name="unit_cost" optional="show"/>
                <field name="vendor_id" optional="show"/>
                <field name="needs_reorder" string="⚠ Reorder"
                       decoration-danger="needs_reorder == True"/>
            </list>
        </field>
    </record>

    <record id="it_consumable_view_form" model="ir.ui.view">
        <field name="name">it.consumable.form</field>
        <field name="model">it.consumable</field>
        <field name="arch" type="xml">
            <form string="IT Consumable">
                <header>
                    <button name="action_issue" string="Issue to Employee"
                            type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-arrow-right" type="button" disabled="1">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="total_issued"/></span>
                                <span class="o_stat_text">Total Issued</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group string="Consumable Details">
                            <field name="name"/>
                            <field name="category"/>
                            <field name="part_number"/>
                            <field name="vendor_id"/>
                            <field name="uom_id"/>
                        </group>
                        <group string="Stock Levels">
                            <field name="quantity_on_hand"/>
                            <field name="reorder_qty"/>
                            <field name="unit_cost"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="needs_reorder" widget="boolean"
                                   decoration-danger="needs_reorder == True" readonly="1"/>
                        </group>
                    </group>
                    <group string="Compatible Asset Categories">
                        <field name="compatible_asset_types" widget="many2many_tags" nolabel="1"/>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Issue History">
                            <field name="issue_ids" readonly="1">
                                <list string="Issues">
                                    <field name="issue_date"/>
                                    <field name="employee_id"/>
                                    <field name="asset_id" optional="show"/>
                                    <field name="quantity_issued"/>
                                    <field name="issued_by"/>
                                    <field name="notes" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Consumable Issue Form (for wizard-style issue) -->
    <record id="it_consumable_issue_view_form" model="ir.ui.view">
        <field name="name">it.consumable.issue.form</field>
        <field name="model">it.consumable.issue</field>
        <field name="arch" type="xml">
            <form string="Issue Consumable">
                <group>
                    <field name="consumable_id"/>
                    <field name="employee_id" required="1"/>
                    <field name="asset_id"/>
                    <field name="quantity_issued"/>
                    <field name="issue_date"/>
                    <field name="notes"/>
                </group>
                <footer>
                    <button string="Issue" name="action_confirm_issue" type="object"
                            class="btn-primary"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="it_consumable_action" model="ir.actions.act_window">
        <field name="name">Consumables</field>
        <field name="res_model">it.consumable</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="it_consumable_action_reorder" model="ir.actions.act_window">
        <field name="name">Consumables — Reorder Needed</field>
        <field name="res_model">it.consumable</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('needs_reorder','=',True)]</field>
    </record>
</odoo>
