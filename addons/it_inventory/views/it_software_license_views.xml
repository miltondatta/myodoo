<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="it_software_license_view_list" model="ir.ui.view">
        <field name="name">it.software.license.list</field>
        <field name="model">it.software.license</field>
        <field name="arch" type="xml">
            <list string="Software Licenses"
                  decoration-success="license_status == 'active'"
                  decoration-warning="license_status == 'expiring'"
                  decoration-danger="license_status in ('expired','over_limit')">
                <field name="name"/>
                <field name="vendor_id"/>
                <field name="version" optional="hide"/>
                <field name="license_type"/>
                <field name="total_seats"/>
                <field name="used_seats"/>
                <field name="available_seats"/>
                <field name="purchase_date" optional="hide"/>
                <field name="expiry_date"/>
                <field name="cost" optional="show"/>
                <field name="license_status" widget="badge"
                       decoration-success="license_status == 'active'"
                       decoration-warning="license_status == 'expiring'"
                       decoration-danger="license_status in ('expired','over_limit')"/>
            </list>
        </field>
    </record>

    <record id="it_software_license_view_form" model="ir.ui.view">
        <field name="name">it.software.license.form</field>
        <field name="model">it.software.license</field>
        <field name="arch" type="xml">
            <form string="Software License">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-tachometer"
                                type="button" disabled="1">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="used_seats"/>/<field name="total_seats"/>
                                </span>
                                <span class="o_stat_text">Seats Used</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group string="License Info">
                            <field name="name"/>
                            <field name="version"/>
                            <field name="vendor_id"/>
                            <field name="license_type"/>
                            <field name="license_key" password="True"/>
                        </group>
                        <group string="Seats &amp; Validity">
                            <field name="total_seats"/>
                            <field name="used_seats" readonly="1"/>
                            <field name="available_seats" readonly="1"/>
                            <field name="purchase_date"/>
                            <field name="expiry_date"/>
                            <field name="license_status" widget="badge"
                                   decoration-success="license_status == 'active'"
                                   decoration-warning="license_status == 'expiring'"
                                   decoration-danger="license_status in ('expired','over_limit')"
                                   readonly="1"/>
                        </group>
                    </group>
                    <group string="Cost">
                        <field name="cost"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="po_id"/>
                    </group>
                    <notebook>
                        <page string="Installed On Assets">
                            <field name="asset_ids" widget="many2many_tags"
                                   domain="[('state','not in',['retired','disposed'])]"/>
                        </page>
                        <page string="Assigned to Employees">
                            <field name="employee_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="it_software_license_action" model="ir.actions.act_window">
        <field name="name">Software Licenses</field>
        <field name="res_model">it.software.license</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="it_software_license_action_expiring" model="ir.actions.act_window">
        <field name="name">Expiring Licenses</field>
        <field name="res_model">it.software.license</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('license_status','in',['expiring','expired','over_limit'])]</field>
    </record>
</odoo>
