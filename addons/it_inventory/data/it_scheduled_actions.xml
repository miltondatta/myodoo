<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="cron_warranty_alerts" model="ir.cron">
        <field name="name">IT Assets: Send Warranty Expiry Alerts</field>
        <field name="model_id" ref="model_it_asset"/>
        <field name="state">code</field>
        <field name="code">model.cron_send_warranty_alerts()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
    </record>

    <record id="cron_license_alerts" model="ir.cron">
        <field name="name">IT Assets: Send License Expiry Alerts</field>
        <field name="model_id" ref="model_it_software_license"/>
        <field name="state">code</field>
        <field name="code">model.cron_send_license_alerts()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
    </record>

    <record id="cron_amc_status" model="ir.cron">
        <field name="name">IT Assets: Recompute AMC Status</field>
        <field name="model_id" ref="model_it_amc"/>
        <field name="state">code</field>
        <field name="code">model.search([])._compute_state()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
    </record>

    <record id="cron_depreciation_update" model="ir.cron">
        <field name="name">IT Assets: Update Book Values (Depreciation)</field>
        <field name="model_id" ref="model_it_asset"/>
        <field name="state">code</field>
        <field name="code">model.cron_update_depreciation()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">weeks</field>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
    </record>

    <record id="cron_warranty_status_update" model="ir.cron">
        <field name="name">IT Assets: Refresh Warranty Status</field>
        <field name="model_id" ref="model_it_asset"/>
        <field name="state">code</field>
        <field name="code">model.cron_update_warranty_status()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
    </record>
</odoo>
