<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_it_asset" model="ir.sequence">
        <field name="name">IT Asset Tag</field>
        <field name="code">it.asset</field>
        <field name="prefix">IT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_it_asset_request" model="ir.sequence">
        <field name="name">IT Asset Request</field>
        <field name="code">it.asset.request</field>
        <field name="prefix">ITREQ/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_it_asset_audit" model="ir.sequence">
        <field name="name">IT Asset Audit</field>
        <field name="code">it.asset.audit</field>
        <field name="prefix">AUDIT/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_it_amc" model="ir.sequence">
        <field name="name">IT AMC Contract</field>
        <field name="code">it.amc</field>
        <field name="prefix">AMC/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_it_ticket" model="ir.sequence">
        <field name="name">IT Support Ticket</field>
        <field name="code">it.ticket</field>
        <field name="prefix">TKT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
